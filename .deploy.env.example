# SSH deploy config — КОПИРАЙ като .deploy.env
# Само за pnpm deploy:remote и db-tunnel.bat
# App secrets (DB, пароли, Mailjet…) живеят в .env — НЕ тук!

JETHOST_SSH_HOST=
JETHOST_SSH_USER=
JETHOST_SSH_PORT=1022
JETHOST_SSH_KEY=

JETHOST_APP_DIR=pamporovo-villa
GITHUB_REPO=https://github.com/Jhoseto/pamporovo-villa.git
