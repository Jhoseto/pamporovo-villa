# JetHost remote deploy config (copy to .deploy.env and fill in)
# Used by: pnpm deploy:remote

# SSH (cPanel -> SSH Access)
JETHOST_SSH_HOST=
JETHOST_SSH_USER=
JETHOST_SSH_PORT=1022
# Path to private key on Windows, e.g. C:\Users\you\.ssh\id_ed25519
JETHOST_SSH_KEY=

# Server app directory (under home)
JETHOST_APP_DIR=pamporovo-villa

# Git repo
GITHUB_REPO=https://github.com/Jhoseto/pamporovo-villa.git

# Production (from cPanel -> MySQL Databases)
DATABASE_URL=mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME

# Temporary URL until pamporovovilla.com DNS is connected
SITE_URL=https://YOUR-TEMP-URL-HERE

# Admin login (leave empty to auto-generate on each secrets run)
MASTER_ADMIN_PASSWORD=

# Optional: GitHub Actions secrets (for pnpm deploy:github-secrets)
# JETHOST_SSH_HOST and JETHOST_SSH_USER are reused above
