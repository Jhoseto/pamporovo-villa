# ═══════════════════════════════════════════════════════════════════════════════
# Pamporovo Villa — ЕДИН env файл за всичко (.env)
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Копирай:  copy .env.example .env   (Windows)  |  cp .env.example .env
# 2. Попълни стойностите по-долу
# 3. Локално:  ./restart.bat  (DB tunnel + dev сървър)
#
# Deploy:
#   - GitHub Actions: secrets от .env → pnpm deploy:github-secrets
#   - Ръчен deploy:   pnpm deploy:remote (качва .env на сървъра)
#
# SSH достъп до сървъра е ОТДЕЛНО в .deploy.env (не е app config)
# ═══════════════════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=3000

# ─── База данни ───────────────────────────────────────────────────────────────
# Локално (XAMPP):     mysql://root@127.0.0.1:3306/pamporovo_villa
# Локално + tunnel:    mysql://USER:PASS@127.0.0.1:3307/DB_NAME  (db-tunnel.bat)
# Production (cPanel): mysql://USER:PASS@localhost:3306/DB_NAME
DATABASE_URL=mysql://root@127.0.0.1:3306/pamporovo_villa

# ─── Admin вход ───────────────────────────────────────────────────────────────
JWT_SECRET=local-dev-change-before-production-min-32-chars
MASTER_ADMIN_USERNAME=Rado
MASTER_ADMIN_PASSWORD=Admin2626

# ─── Push известия (admin PWA) ────────────────────────────────────────────────
# Генерирай: node scripts/generate-vapid.mjs  или  pnpm secrets:prod
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:pamporovovilla@gmail.com

# ─── Сайт URL ─────────────────────────────────────────────────────────────────
# Локално: http://localhost:3000
# Production: https://pamporovovilla.com
SITE_URL=http://localhost:3000

# ─── Имейл — Mailjet (препоръчително, 6000/мес. безплатно) ───────────────────
# https://www.mailjet.com/ → API keys + verify sender domain (SPF/DKIM)
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAIL_FROM_EMAIL=noreply@pamporovovilla.com
MAIL_FROM_NAME=Pamporovo Villa
SUPPORT_EMAIL=pamporovovillasupport@gmail.com
SMTP_REPLY_TO=pamporovovillasupport@gmail.com

# ─── Production only ──────────────────────────────────────────────────────────
# TRUST_PROXY=1

# ─── Google Analytics 4 (client — public site only) ───────────────────────────
# Default in code: G-6W50FH0F0D (override if using a different GA4 property)
# VITE_GA4_MEASUREMENT_ID=G-6W50FH0F0D

# ─── i18n auto-translation (DeepL) ────────────────────────────────────────────
# Run i18n-sync.bat after editing Bulgarian locale files in shared/locales/bg/
# Free API keys end with :fx — uses api-free.deepl.com automatically
DEEPL_API_KEY=

# ─── Optional: Umami analytics (client) ───────────────────────────────────────
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=
