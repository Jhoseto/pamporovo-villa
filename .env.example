# ─── Локална разработка ───
# Копирай като .env и пусни: pnpm db:push && ./restart.bat
# Сайт: http://localhost:3000
# Admin: http://localhost:3000/admin

NODE_ENV=development
PORT=3000

# MySQL на localhost (създай база pamporovo_villa преди db:push)
# Без парола (XAMPP/Laragon): mysql://root@127.0.0.1:3306/pamporovo_villa
# С парола:                  mysql://root:password@127.0.0.1:3306/pamporovo_villa
# Docker (pnpm db:docker):    mysql://pamporovo:pamporovo@127.0.0.1:3306/pamporovo_villa
DATABASE_URL=mysql://root@127.0.0.1:3306/pamporovo_villa

JWT_SECRET=local-dev-change-before-production
MASTER_ADMIN_USERNAME=Rado
MASTER_ADMIN_PASSWORD=Admin2626

# node scripts/generate-vapid.mjs
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:pamporovovilla@gmail.com
