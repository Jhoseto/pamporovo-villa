# ─── Production (JetHost) ───
# Копирай на сървъра като ~/pamporovo-villa/.env
# Или задай същите ключове в cPanel -> Setup Node.js App -> Environment variables

NODE_ENV=production
PORT=3000
TRUST_PROXY=1

# Временен URL докато pamporovovilla.com не е свързан (смени след DNS)
# Пример: https://account123.jethost.com или URL от cPanel Node.js App
SITE_URL=https://YOUR-TEMP-URL-HERE

# MySQL от cPanel -> MySQL Databases
DATABASE_URL=mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME

# Генерирай: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-long-random-secret-min-32-chars

MASTER_ADMIN_USERNAME=Rado
MASTER_ADMIN_PASSWORD=strong-password-here

# Push известия: node scripts/generate-vapid.mjs
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:pamporovovilla@gmail.com

# Имейл при потвърждение на резервация (по избор)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=pamporovovilla@gmail.com
# SMTP_PASS=app-password
# SMTP_FROM=Pamporovo Villa <pamporovovilla@gmail.com>
